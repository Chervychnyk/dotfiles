{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-interview",
    "npm:pi-mcp-adapter",
    "npm:pi-intercom",
    "~/code/pi-web-tools",
    "npm:pi-code-previews"
  ],
  "theme": "everforest-dark-hard",
  "workingVibe": "zen",
  "defaultThinkingLevel": "low",
  "quietStartup": true,
  "collapseChangelog": true,
  "hideThinkingBlock": false,
  "steeringMode": "all",
  "followUpMode": "all",
  "doubleEscapeAction": "tree",
  "codePreview": {
    "shikiTheme": "everforest-dark",
    "wordEmphasis": "all",
    "toolCallBackground": "border",
    "toolCallTiming": true,
    "readContentPreview": false,
    "writeContentPreview": true,
    "editDiffPreview": true,
    "grepResultPreview": false,
    "findResultPreview": false,
    "lsResultPreview": false,
    "bashResultPreview": true,
    "grepCollapsedLines": 40,
    "pathListCollapsedLines": 40,
    "tools": [
      "bash",
      "write",
      "edit",
      "find",
      "ls"
    ]
  }
}
