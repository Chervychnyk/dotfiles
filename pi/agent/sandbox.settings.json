{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "npmjs.org",
      "*.npmjs.org",
      "registry.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com",
      "sentry.themindstudios.com",
      "localhost",
      "127.0.0.1"
    ],
    "allowUnixSockets": [
      "~/.colima/default/docker.sock",
      "/var/run/docker.sock"
    ],
    "allowLocalBinding": true
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "/private/tmp",
      "~/.cache",
      "~/.npm",
      "~/.local/share/nvim",
      "~/.local/state/nvim",
      "~/.pi/cache"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ]
  }
}
