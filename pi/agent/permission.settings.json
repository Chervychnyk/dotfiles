{
  "defaultMode": "ask",
  "allow": [
    "read",
    "grep",
    "find",
    "ls",
    "bash(cd *)",
    "bash(pwd)",
    "bash(ls *)",
    "bash(which *)",
    "bash(command -v *)",
    "bash(git status*)",
    "bash(git diff*)",
    "bash(git log*)",
    "bash(git show*)",
    "bash(git branch*)",
    "bash(git rev-parse*)",
    "bash(git ls-files*)"
  ],
  "deny": [
    "read(.env*)",
    "read(*.env*)",
    "read(*auth.json)",
    "read(*credentials*)",
    "read(*credentials.yml.enc)",
    "read(*master.key)",
    "read(*secrets.yml)",
    "bash(rm -rf *)",
    "bash(sudo *)",
    "bash(chmod * 777*)",
    "bash(chown * 777*)",
    "bash(kubectl delete *)",
    "bash(docker system prune*)",
    "bash(git push --force*)",
    "bash(git reset --hard*)"
  ],
  "ask": [
    "bash",
    "edit",
    "write",
    "bash(git push *)",
    "bash(docker compose down*)"
  ],
  "diffRenderer": "shiki",
  "shikiTheme": "everforest-dark",
  "keybindings": {
    "autoAcceptEdits": "ctrl+shift+y"
  }
}
