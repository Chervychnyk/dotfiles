{
  "enabled": true,
  "features": {
    "policies": true,
    "permissionGate": true
  },
  "policies": {
    "rules": [
      {
        "id": "secret-files",
        "description": "Block access to env files and Rails secret material",
        "patterns": [
          {
            "pattern": ".env"
          },
          {
            "pattern": ".env.*"
          },
          {
            "pattern": ".npmrc"
          },
          {
            "pattern": ".pypirc"
          },
          {
            "pattern": "config/secrets.yml"
          },
          {
            "pattern": "config/application.yml"
          },
          {
            "pattern": "config/database.yml"
          },
          {
            "pattern": "config/credentials.yml"
          },
          {
            "pattern": "config/credentials.yml.enc"
          },
          {
            "pattern": "config/master.key"
          },
          {
            "pattern": "config/credentials/*.key"
          },
          {
            "pattern": "config/credentials/*.yml.enc"
          },
          {
            "pattern": "**/.bundle/config"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": ".env.example"
          },
          {
            "pattern": ".env.sample"
          },
          {
            "pattern": ".env.template"
          },
          {
            "pattern": ".env.test"
          },
          {
            "pattern": "*.example.env"
          },
          {
            "pattern": "*.sample.env"
          },
          {
            "pattern": "*.test.env"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "blockMessage": "Accessing {file} is not allowed. This file likely contains secrets or machine-local credentials. Explain why you need it, and ask the user to inspect or edit it manually if needed."
      },
      {
        "id": "key-material",
        "description": "Block certificates, private keys, and SSH material",
        "patterns": [
          {
            "pattern": "*.pem"
          },
          {
            "pattern": "*.key"
          },
          {
            "pattern": "*.p12"
          },
          {
            "pattern": "*.pfx"
          },
          {
            "pattern": "*.jks"
          },
          {
            "pattern": "*.keystore"
          },
          {
            "pattern": "*.der"
          },
          {
            "pattern": "*.crt"
          },
          {
            "pattern": "*.cer"
          },
          {
            "pattern": "id_rsa"
          },
          {
            "pattern": "id_rsa.pub"
          },
          {
            "pattern": "**/.ssh/**"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "blockMessage": "Accessing {file} is not allowed. This path may contain sensitive key material."
      },
      {
        "id": "git-internals",
        "description": "Block direct access to Git internals",
        "patterns": [
          {
            "pattern": "**/.git/**"
          }
        ],
        "protection": "noAccess",
        "onlyIfExists": true,
        "blockMessage": "Accessing {file} is not allowed. Use git commands instead of reading or editing Git internals directly."
      },
      {
        "id": "dependency-vendors",
        "description": "Prevent modifying vendored dependencies",
        "patterns": [
          {
            "pattern": "**/node_modules/**"
          },
          {
            "pattern": "vendor/bundle/**"
          },
          {
            "pattern": "vendor/cache/**"
          },
          {
            "pattern": ".venv/**"
          },
          {
            "pattern": "venv/**"
          },
          {
            "pattern": "site-packages/**"
          }
        ],
        "protection": "readOnly",
        "onlyIfExists": true,
        "blockMessage": "Writing to {file} is not allowed. Vendored dependencies and virtual environments are read-only."
      },
      {
        "id": "generated-lockfiles-and-schema",
        "description": "Require explicit intent for lockfiles and generated schema artifacts",
        "patterns": [
          {
            "pattern": "Gemfile.lock"
          },
          {
            "pattern": "package-lock.json"
          },
          {
            "pattern": "pnpm-lock.yaml"
          },
          {
            "pattern": "yarn.lock"
          },
          {
            "pattern": "poetry.lock"
          },
          {
            "pattern": "Pipfile.lock"
          },
          {
            "pattern": "uv.lock"
          },
          {
            "pattern": "db/schema.rb"
          },
          {
            "pattern": "db/structure.sql"
          }
        ],
        "protection": "readOnly",
        "onlyIfExists": true,
        "blockMessage": "Writing to {file} is blocked by default because it is usually generated or managed by tooling. Prefer changing source files and regenerating it intentionally."
      }
    ]
  },
  "permissionGate": {
    "requireConfirmation": true,
    "patterns": [
      {
        "pattern": "docker compose down -v",
        "description": "remove containers, networks, and volumes"
      },
      {
        "pattern": "docker-compose down -v",
        "description": "remove containers, networks, and volumes"
      },
      {
        "pattern": "docker system prune",
        "description": "remove Docker data globally"
      },
      {
        "pattern": "docker volume rm",
        "description": "delete Docker volumes"
      },
      {
        "pattern": "dropdb",
        "description": "drop a database"
      },
      {
        "pattern": "rails db:drop",
        "description": "drop the Rails database"
      },
      {
        "pattern": "rails db:reset",
        "description": "drop and recreate the Rails database"
      },
      {
        "pattern": "rails db:purge",
        "description": "purge the Rails database"
      },
      {
        "pattern": "psql -c DROP DATABASE",
        "description": "drop a Postgres database"
      },
      {
        "pattern": "kubectl delete",
        "description": "delete Kubernetes resources"
      }
    ],
    "autoDenyPatterns": [
      {
        "pattern": "git push --force",
        "regex": true
      },
      {
        "pattern": "git push -f",
        "regex": true
      },
      {
        "pattern": "--force-with-lease",
        "regex": true
      },
      {
        "pattern": "\\brm\\b[^\\n]*\\*",
        "regex": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-04-11T04:44:06.987Z",
    "version": "0.9.0-20260327"
  }
}
