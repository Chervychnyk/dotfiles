/**
 * Safe Guard Extension
 *
 * 1) Hard-blocks a few high-risk bash patterns (force push, git add -A, wildcard rm)
 * 2) Requires confirmation for other destructive-looking commands
 * 3) Protects sensitive paths from write/edit operations
 */
import path from "node:path";
import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";

interface RejectRule {
  pattern: RegExp;
  reason: string;
}

export const ALWAYS_REJECT_RULES: RejectRule[] = [
  {
    pattern: /(^|[;&|]\s*)git\s+add\s+(?:-A|\.)(\s|$)/i,
    reason: "Blocked: use explicit 'git add <file>' instead of 'git add -A' or 'git add .'.",
  },
  {
    pattern: /\bgit\s+push\b[^\n]*(?:--force-with-lease|--force|-f)(\s|$)/i,
    reason: "Blocked: never force push from the agent.",
  },
  {
    pattern: /\brm\s+-[^\n]*f[^\n]*\s+\*/i,
    reason: "Blocked: forceful wildcard rm is not allowed.",
  },
  {
    pattern: /(^|[;&|]\s*)rm\s+\*(\s|$)/i,
    reason: "Blocked: wildcard rm is not allowed. Use 'trash <file>' for recoverable deletion.",
  },
  {
    pattern: /(?:&&|\|\||;)\s*rm\s+\S+/i,
    reason: "Blocked: chained rm commands are not allowed.",
  },
];

export const DANGEROUS_PATTERNS = [
  /\brm\s+(-[a-zA-Z]*f[a-zA-Z]*\s+|.*-rf\b|.*--force\b)/,
  /\bsudo\s+rm\b/,
  /\b(DROP|TRUNCATE|DELETE\s+FROM)\b/i,
  /\bchmod\s+777\b/,
  /\bmkfs\b/,
  /\bdd\s+if=/,
  />\s*\/dev\/sd[a-z]/,
  /\bgit\s+reset\s+--hard\b/i,
  /\bgit\s+clean\s+-[a-z]*f[a-z]*\b/i,
];

const ENV_EXCEPTIONS = new Set([".env.example", ".env.sample", ".env.template"]);

function extractBashCommand(input: unknown): string {
  const value = input as { command?: unknown; cmd?: unknown } | undefined;
  if (!value) return "";
  if (typeof value.command === "string") return value.command;
  if (typeof value.cmd === "string") return value.cmd;
  return "";
}

function matchProtectedPath(filePath: string): string | undefined {
  if (!filePath) return undefined;

  const normalized = filePath.replace(/\\/g, "/");
  const basename = path.basename(normalized);

  if ((basename === ".env" || basename.startsWith(".env.")) && !ENV_EXCEPTIONS.has(basename)) {
    return basename;
  }
  if (/(^|\/)id_rsa(\.pub)?$/.test(normalized)) return "id_rsa";
  if (/(^|\/)\.ssh(\/|$)/.test(normalized)) return ".ssh/";
  if (/(^|\/)\.git(\/|$)/.test(normalized)) return ".git/";
  if (/(^|\/)\.pi(\/|$)/.test(normalized)) return ".pi/";
  if (/(^|\/)node_modules(\/|$)/.test(normalized)) return "node_modules/";

  return undefined;
}

export default function (pi: ExtensionAPI) {
  pi.on("tool_call", async (event, ctx) => {
    if (event.toolName === "bash") {
      const cmd = extractBashCommand(event.input).trim();
      if (!cmd) return;

      const hardBlock = ALWAYS_REJECT_RULES.find((rule) => rule.pattern.test(cmd));
      if (hardBlock) {
        return { block: true, reason: hardBlock.reason };
      }

      const dangerous = DANGEROUS_PATTERNS.some((p) => p.test(cmd));
      if (!dangerous) return;

      if (!ctx.hasUI) {
        return {
          block: true,
          reason: "Blocked in non-interactive mode: potentially destructive command.",
        };
      }

      const ok = await ctx.ui.confirm("⚠️ Dangerous Command", `Execute: ${cmd}?`);
      if (!ok) return { block: true, reason: "Blocked by user" };
      return;
    }

    if (event.toolName === "write" || event.toolName === "edit") {
      const targetPath = (event.input as { path?: string }).path ?? "";
      const hit = matchProtectedPath(targetPath);
      if (!hit) return;

      if (!ctx.hasUI) {
        return { block: true, reason: `Protected path: ${hit}` };
      }

      const ok = await ctx.ui.confirm("🛡️ Protected Path", `Allow write to ${targetPath}?`);
      if (!ok) return { block: true, reason: `Protected path: ${hit}` };
    }
  });
}
